# ── 사람인 Open API ──────────────────────────────────────────────
# https://oapi.saramin.co.kr 에서 발급 (없으면 HTML 크롤링으로 폴백)
SARAMIN_API_KEY=your_saramin_api_key_here

# ── Chrome 브라우저 경로 (자동 감지 실패 시) ─────────────────────
# CHROME_BIN=C:\Program Files\Google\Chrome\Application\chrome.exe

# ── OpenAI 임베딩 (대시보드 openai 모드 사용 시) ─────────────────
# OPENAI_API_KEY=your_openai_api_key_here

# ── AWS Bedrock 임베딩 (대시보드 bedrock 모드 사용 시) ───────────
# AWS_REGION=us-east-1
