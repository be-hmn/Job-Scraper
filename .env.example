# ── Google Gemini (쿼리 확장 LLM) ────────────────────────────────
# https://aistudio.google.com/app/apikey 에서 발급
# Free tier  : GEMINI_MODEL=gemini-2.0-flash-lite  (기본값, 최소 토큰)
# Advanced   : GEMINI_MODEL=gemini-2.5-flash        (더 정확한 확장)
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.5-flash


# https://oapi.saramin.co.kr 에서 발급 (없으면 HTML 크롤링으로 폴백)
SARAMIN_API_KEY=your_saramin_api_key_here

# ── Chrome 브라우저 경로 (자동 감지 실패 시) ─────────────────────
# CHROME_BIN=C:\Program Files\Google\Chrome\Application\chrome.exe

# ── 서비스 식별 정보 (크롤러 매너 — 실제 정보로 변경하세요) ────────
# 수집 사이트 운영자가 문의할 수 있도록 연락처를 남깁니다.
# SERVICE_NAME=IT-Job-Scraper
# SERVICE_CONTACT=your-email@example.com
# SERVICE_URL=https://github.com/be-hmn/Job-Scraper

# ── 크롤링 딜레이 조절 (초) ──────────────────────────────────────
# 차단이 잦으면 값을 늘리세요. 기본: 3~7초 랜덤
# CRAWL_DELAY_MIN=3
# CRAWL_DELAY_MAX=7

# ── OpenAI 임베딩 (대시보드 openai 모드 사용 시) ─────────────────
# OPENAI_API_KEY=your_openai_api_key_here

# ── AWS Bedrock 임베딩 (대시보드 bedrock 모드 사용 시) ───────────
# AWS_REGION=us-east-1
