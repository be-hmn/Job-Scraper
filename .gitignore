# ── 환경 변수 (API 키 포함 - 절대 커밋 금지) ────────────────────
.env

# ── Streamlit secrets (API 키 포함 - 절대 커밋 금지) ────────────
.streamlit/secrets.toml

# ── 수집 결과 (용량 크고 재생성 가능) ───────────────────────────
# output/ 전체 대신 파일 단위로 무시 — DB는 Cloud 배포를 위해 추적
output/*.csv
output/*.log
output/.gitkeep
# DB와 통계는 추적 (Streamlit Cloud가 읽어야 함)
# output/job_database.db  → 추적
# output/pipeline_stats.json → 추적

# ── Python 캐시 ──────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# ── 가상환경 ─────────────────────────────────────────────────────
venv/
.venv/
env/

# ── IDE ──────────────────────────────────────────────────────────
.vscode/
.idea/

# ── OS ───────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── 로그 ─────────────────────────────────────────────────────────
*.log

# ── WebDriver 캐시 ───────────────────────────────────────────────
.wdm/
/downloaded_files/driver_fixing.lock
/downloaded_files/pyautogui.lock
