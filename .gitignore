# ── 환경 변수 (API 키 포함 - 절대 커밋 금지) ────────────────────
.env

# ── Streamlit secrets (API 키 포함 - 절대 커밋 금지) ────────────
.streamlit/secrets.toml

# ── 수집 결과 (용량 크고 재생성 가능) ───────────────────────────
output/
# output/ 폴더 자체는 무시하되 .gitkeep은 추적 (폴더 구조 유지)
!output/.gitkeep

# ── Python 캐시 ──────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# ── 가상환경 ─────────────────────────────────────────────────────
venv/
.venv/
env/

# ── IDE ──────────────────────────────────────────────────────────
.vscode/
.idea/

# ── OS ───────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── 로그 ─────────────────────────────────────────────────────────
*.log

# ── WebDriver 캐시 ───────────────────────────────────────────────
.wdm/
