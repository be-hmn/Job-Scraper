# Streamlit Cloud 배포 시 이 파일을 참고하여
# 대시보드 Settings → Secrets 에 아래 키를 등록하세요.
# 로컬에서는 .env 파일을 사용하므로 이 파일은 필요 없습니다.

# Google Gemini (쿼리 확장 LLM)
GEMINI_API_KEY = "your_gemini_api_key"
GEMINI_MODEL   = "gemini-2.0-flash-lite"

# 사람인 Open API (선택)
SARAMIN_API_KEY = "your_saramin_api_key"

# OpenAI (선택 — Gemini 없을 때 폴백)
# OPENAI_API_KEY = "sk-..."

# AWS Bedrock (선택 — OpenAI도 없을 때 폴백)
# AWS_ACCESS_KEY_ID     = "AKIA..."
# AWS_SECRET_ACCESS_KEY = "..."
# AWS_REGION            = "us-east-1"
